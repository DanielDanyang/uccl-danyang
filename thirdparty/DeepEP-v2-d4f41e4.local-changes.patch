+        const auto [exit_code, symbols] = call_external_command(fmt::format("{} -symbols {}", cuobjdump_path.c_str(), cubin_path.c_str()));
+        if (exit_code == 0) {
+            std::istringstream iss(symbols);
+            for (std::string line; std::getline(iss, line); ) {
+                if (line.find("STT_FUNC") == 0 and line.find("STO_ENTRY") != std::string::npos and
+                    std::none_of(illegal_names.begin(), illegal_names.end(),
+                    [&](const auto name) { return line.find(name) != std::string::npos; })) {
+                    const auto last_space = line.rfind(' ');
+                    symbol_names.push_back(line.substr(last_space + 1));
+                }
+            }
+        } else {
+            if (get_env<int>("EP_JIT_DEBUG"))
+                printf("cuobjdump failed with exit code %d, falling back to nm for: %s\n",
+                       exit_code, cubin_path.c_str());
+            // Some AWS CUDA toolkit images include nvcc but not cuobjdump.  A
+            // CUBIN is still an ELF object, so GNU nm can recover the unique
+            // global text symbol used by DeepEP JIT kernels.
+            const auto [nm_exit_code, nm_symbols] = call_external_command(fmt::format("nm {}", cubin_path.c_str()));
+            EP_HOST_ASSERT(nm_exit_code == 0);
+            std::istringstream iss(nm_symbols);
+            for (std::string line; std::getline(iss, line); ) {
+                if (line.find(" T ") != std::string::npos and
+                    std::none_of(illegal_names.begin(), illegal_names.end(),
+                    [&](const auto name) { return line.find(name) != std::string::npos; })) {
+                    const auto last_space = line.rfind(' ');
+                    symbol_names.push_back(line.substr(last_space + 1));
+                }
             }
         }
 
