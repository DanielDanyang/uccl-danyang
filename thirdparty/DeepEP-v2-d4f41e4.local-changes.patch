+    // Expose the resources the native UCCL/EFA dispatch path needs.
+    //
+    // The device segment of the symmetric window is one contiguous mapped range
+    //   [ Workspace | GPU buffer ]   (= nccl_context->num_gpu_bytes, HBM)
+    // (see the constructor: `buffer = workspace + num_workspace_bytes`).  The
+    // native EFA path registers ONLY this device segment as a single MR; the
+    // trailing CPU/engram segment is NUMA/host memory and is deliberately not
+    // covered here.  All pointers are plain integer addresses so the Python
+    // wrapper can register the MR and derive `req_lptr/req_rptr` window offsets.
+    //
+    // Two distinct base pointers are returned on purpose:
+    //   * `workspace_ptr`        -- the mapped (LSA) view the kernel dereferences
+    //                               and computes window offsets against.
+    //   * `rdma_workspace_ptr`   -- the raw symmetric base to register as the EFA
+    //                               MR and advertise to peers.  It has the same
+    //                               internal layout as the mapped view, so a
+    //                               window offset is valid against either base.
+    pybind11::dict get_native_v2_resources() const {
+        EP_HOST_ASSERT(not destroyed);
+        const auto as_uint = [](const void* p) {
+            return reinterpret_cast<std::uintptr_t>(p);
+        };
+        const int64_t workspace_bytes =
+            static_cast<uint8_t*>(buffer) - static_cast<uint8_t*>(workspace);
+
+        pybind11::dict d;
+        // Sizes (bytes).
+        d["workspace_bytes"] = workspace_bytes;
+        d["buffer_bytes"] = num_gpu_buffer_bytes;           // GPU buffer only (HBM)
+        d["cpu_buffer_bytes"] = num_cpu_buffer_bytes;       // local rank's CPU/engram size
+
+        // Mapped (LSA) device pointers -- what the kernel dereferences.
+        d["workspace_ptr"] = as_uint(workspace);
+        d["buffer_ptr"] = as_uint(buffer);
+
+        // Raw symmetric base -- registered as the EFA MR / advertised to peers.
+        d["rdma_workspace_ptr"] = as_uint(nccl_context->get_raw_window_ptr());
+
+        // Host-side mirror of the workspace (mapped + host VA).
+        d["mapped_host_workspace_ptr"] = as_uint(mapped_host_workspace);
+        d["host_workspace_ptr"] = as_uint(host_workspace);
+
+        // NCCL device handles for the untouched scale-up (NVLink GIN) path.
+        d["nccl_dev_comm_ptr"] = as_uint(&nccl_context->dev_comm);
+        d["nccl_window_ptr"] = as_uint(nccl_context->window);
+
+        // NOTE: the CPU/engram base pointer and the FULL registered window size
+        // are intentionally NOT exported. In hybrid mode the registered window is
+        // `num_gpu_bytes + num_cpu_bytes * num_scaleup_ranks` and the CPU segment
+        // is per-scaleup-rank NUMA memory (symmetric.hpp HybridElasticSymmetric-
+        // Memory), so `buffer + gpu_bytes` would only be rank0's CPU base. The
+        // native EFA path touches neither; add a hybrid-correct getter here if
+        // combine/engram ever needs the CPU segment.
+        return d;
+    }
+
